# Secret-free NewAPI / OpenAI-compatible model pool example.
# Copy this file to .env for local use. Do not edit this tracked example with
# real credentials.

# NewAPI/OpenAI-compatible gateway base URL.
# Use an HTTPS URL for shared or remote gateways.
NORION_NEWAPI_BASE_URL=https://newapi.example.invalid

# Placeholder only. Store the real key in a local untracked .env file or a
# deployment secret manager.
NORION_NEWAPI_API_KEY=replace-with-secret-from-vault

# Explicit comma-separated allowlist. Do not use wildcards such as *, all,
# latest, or default. GPT-5-family IDs remain blocked even if listed here.
NORION_NEWAPI_ALLOWED_MODELS=claude-sonnet-4,o3-mini,gemini-2.5-pro
